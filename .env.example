# Postgres (consumed by docker-compose.yml)
POSTGRES_USER=fyp
POSTGRES_PASSWORD=change_me
POSTGRES_DB=fyp
POSTGRES_PORT=5432

# App
NODE_ENV=development
# Must match the Postgres credentials above
DATABASE_URL=postgresql://fyp:change_me@localhost:5432/fyp
# 32+ char secret used to sign session JWTs. Generate one with:
#   openssl rand -base64 32
SESSION_SECRET=
# Base URL used to build password-reset links
APP_URL=http://localhost:3000

# SMTP credentials for sending password-reset emails
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="Ecommerce App <no-reply@example.com>"
