# Postgres (used by docker-compose.yml)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=fyp_project
POSTGRES_PORT=5432

# App database connection (must point at the same database as above)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fyp_project

NODE_ENV=development
APP_URL=http://localhost:3000

# Generate with: openssl rand -base64 32
SESSION_SECRET=

# SMTP (password-reset emails). Any provider works — for local testing use
# a service like Mailtrap or Ethereal.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# AI/ML forecasting service (ml-service/) — must match its own ML_SERVICE_API_KEY
ML_SERVICE_URL=http://localhost:5001
ML_SERVICE_API_KEY=
